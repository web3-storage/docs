.navbar {
	width: 100%;
	position: sticky;
	background-color: $w3storage-red;
	border: 0px;

	.logo {
		height: 2.5rem;
		margin: 0;
		padding: 2px 3px 0px 0;
		vertical-align: top;
	}

	.site-name {
		font-size: 1.5rem;
		letter-spacing: -0.05rem;
		background: url('/images/w3storage-logo-text.svg') no-repeat;
		background-position: 0 6px;
		text-indent: -99999px;
		min-width: 220px;
		min-height: 50px;
		background-size: contain;
	}

	.sidebar-button {
		color: $w3storage-blue-dark;
		padding: 0.4rem;

		.icon {
			width: 1.75rem;
			height: 1.75rem;
		}
	}
}

header.navbar .links {
	background-color: $layoutBgColor;
}

.theme-container .nav-links a {
	color: $w3storage-blue-dark;
	font-weight: 600;
}

.theme-container .nav-links a {
	border-bottom: solid 1px transparent !important;
	transition:
		border-color 0.3s ease,
		color 0.3s ease;
}

.theme-container .nav-item > a:hover, .theme-container .nav-item > a.router-link-active {
	border-bottom-color: $w3storage-blue-dark !important;
	color: $w3storage-blue-dark;
}

@media screen and (min-width: 719px) {
	.theme-container .nav-links .nav-item {
		margin-left: 3rem;
	}
}

#algolia-search-input {
	border-radius: 0;
	border: none;
}

header.navbar .links input {
	font-family: inherit;
	border-radius: 0;
	border: 0;
	color: $textColor;
	background-color: $contentBgColor;
	margin-top: 0.1em;
}

header.navbar .links ul {
	border-radius: 0;
	padding: 0;
	border: 2px solid $w3storage-red;
	li {
		border-radius: 0;
	}
	.focused, li:active {
		background-color: $layoutBgColor;
	}
	a {
		color: $linkColor;
	}
}

// DocSearch
// See https://docsearch.algolia.com/docs/styling/
header.navbar .algolia-autocomplete {
	.algolia-docsearch-suggestion--highlight {
		color: $linkColor;
		box-shadow: inset 0 -2px 0 0 alpha($linkColor, 80%);
	}

	.algolia-docsearch-suggestion--title .aa-suggestion-title-separator {
		padding: 0 0.312rem;
	}

	.algolia-docsearch-suggestion--no-results {
		padding-left: 8px;
	}
}

@media (min-width: $MQNarrow) {
	header.navbar .links {
		input {
			width: 0;
			background-color: transparent;
			background: url("data:image/svg+xml,%3C%3Fxml version='1.0' encoding='UTF-8'%3F%3E%3Csvg xmlns='http://www.w3.org/2000/svg' width='30' height='31'%3E%3Cg stroke-width='2' stroke='%23171691' fill='none'%3E%3Cpath d='M11.29 11.71l-4-4'/%3E%3Ccircle cx='7' cy='5' r='4'/%3E%3C/g%3E%3C/svg%3E%0A") 0.7rem 0.7rem no-repeat;
		}

		.suggestions {
			width: 22.5em;
			background-color: $layoutBgColor;
			a {
				color: $w3storage-purple;
			}
			a:hover {
				color: $w3storage-yellow;
			}
			padding-bottom: 0.5em;
		}

		input:focus {
			width: 20em;
			background: url("data:image/svg+xml,%3C%3Fxml version='1.0' encoding='UTF-8'%3F%3E%3Csvg xmlns='http://www.w3.org/2000/svg' width='30' height='31'%3E%3Cg stroke-width='2' stroke='%23ffffff' fill='none'%3E%3Cpath d='M11.29 11.71l-4-4'/%3E%3Ccircle cx='5' cy='5' r='4'/%3E%3C/g%3E%3C/svg%3E%0A") 0.7rem 0.7rem no-repeat;
			background-color: $contentBgColor;
		}
	}
}

@media (max-width: $MQMobile) {
	header.navbar .links {
		input {
			margin-right: 0.4em;
			background-color: transparent;
			background: url("data:image/svg+xml,%3C%3Fxml version='1.0' encoding='UTF-8'%3F%3E%3Csvg xmlns='http://www.w3.org/2000/svg' width='30' height='31'%3E%3Cg stroke-width='2' stroke='%23171691' fill='none'%3E%3Cpath d='M11.29 11.71l-4-4'/%3E%3Ccircle cx='7' cy='5' r='4'/%3E%3C/g%3E%3C/svg%3E%0A") 0.6rem 0.5rem no-repeat;

			// prevent zooming on iOS
			box-sizing: border-box;
			font-size: 1rem;

			&:focus {
				width: 87.5vw;
				background: url("data:image/svg+xml,%3C%3Fxml version='1.0' encoding='UTF-8'%3F%3E%3Csvg xmlns='http://www.w3.org/2000/svg' width='30' height='31'%3E%3Cg stroke-width='2' stroke='%23ffffff' fill='none'%3E%3Cpath d='M11.29 11.71l-4-4'/%3E%3Ccircle cx='7' cy='5' r='4'/%3E%3C/g%3E%3C/svg%3E%0A") 0.6rem 0.5rem no-repeat;
				background-color: $contentBgColor;
			}
		}
		.suggestions {
			width: 87vw;
			border: 2px solid $w3storage-purple;
			background-color: $layoutBgColor;
			a {
				color: $w3storage-purple;
			}
			a:hover {
				color: $w3storage-yellow;
			}
			padding-top: 0.4em;
			padding-bottom: 0.5em;
			margin-top: 0;
			margin-right: 5px;
		}
	}

	.home-link {
		position: absolute;
		width: 45px;
		left: calc(50% - 45px / 2);
	}
}